---
- name: Patch srsUE configmap - add GNU Radio scripts
  ansible.builtin.blockinfile:
    path: "{{ repo_dest_abs }}/charts/srsue/templates/configmap.yaml"
    marker: "# {mark} GNU RADIO SCRIPTS"
    insertafter: "^data:$"
    block: |
      {{ '  start_gnu.sh: |' }}
      {{ '    #!/bin/bash' }}
      {{ '    UE_COUNT=${1:-1}' }}
      {{ '    LOG=/var/log/gnu_multi_ue.log' }}
      {{ '    mkdir -p /var/log' }}
      {{ '    echo "Starting GNU Radio broker for ${UE_COUNT} UEs..." | tee $LOG' }}
      {{ '    exec python3 /srsran/config/multi_ue_scenario.py --nof-ues ${UE_COUNT} >> $LOG 2>&1' }}
      {{ '  multi_ue_scenario.py: |' }}
      {{ '    #!/usr/bin/env python3' }}
      {{ '    from gnuradio import gr, zeromq, blocks' }}
      {{ '    import argparse, signal, sys, os' }}
      {{ '    GNB_IP = os.environ.get("GNB_IP", "' }}{{ srsran_network.n3.gnb_ip }}{{ '")' }}
      {{ '    UE_IPS = os.environ.get("UE_IPS", "' }}{{ srsran_network.n3.ue_ips | join(',') }}{{ '").split(",")' }}
      {{ '    class MultiUEBroker(gr.top_block):' }}
      {{ '        def __init__(self, nof_ues):' }}
      {{ '            gr.top_block.__init__(self, "MultiUE ZMQ Broker")' }}
      {{ '            gnb_src = zeromq.req_source(gr.sizeof_gr_complex, 1, f"tcp://{GNB_IP}:2000", 100, False, -1)' }}
      {{ '            for i in range(nof_ues):' }}
      {{ '                ue_sink = zeromq.rep_sink(gr.sizeof_gr_complex, 1, f"tcp://{UE_IPS[i]}:{2100 + i*100}", 100, False, -1)' }}
      {{ '                self.connect(gnb_src, ue_sink)' }}
      {{ '            adder = blocks.add_cc(1)' }}
      {{ '            for i in range(nof_ues):' }}
      {{ '                ue_src = zeromq.rep_source(gr.sizeof_gr_complex, 1, f"tcp://{UE_IPS[i]}:{2101 + i*100}", 100, False, -1)' }}
      {{ '                self.connect(ue_src, (adder, i))' }}
      {{ '            gnb_sink = zeromq.req_sink(gr.sizeof_gr_complex, 1, f"tcp://{GNB_IP}:2001", 100, False, -1)' }}
      {{ '            self.connect(adder, gnb_sink)' }}
      {{ '    if __name__ == "__main__":' }}
      {{ '        parser = argparse.ArgumentParser()' }}
      {{ '        parser.add_argument("--nof-ues", type=int, default=1)' }}
      {{ '        args = parser.parse_args()' }}
      {{ '        tb = MultiUEBroker(args.nof_ues)' }}
      {{ '        tb.start()' }}
      {{ '        print("Press Enter to quit", flush=True)' }}
      {{ '        def handler(*_):' }}
      {{ '            tb.stop(); tb.wait(); sys.exit(0)' }}
      {{ '        signal.signal(signal.SIGTERM, handler)' }}
      {{ '        try:' }}
      {{ '            tb.wait()' }}
      {{ '        except KeyboardInterrupt:' }}
      {{ '            tb.stop(); tb.wait()' }}

- name: Patch srsUE deployment - add GNB_IP and UE_IPS env vars
  ansible.builtin.replace:
    path: "{{ repo_dest_abs }}/charts/srsue/templates/deployment.yaml"
    regexp: '(\s+)env:(\s+- name: PATH)'
    replace: |
      \1env:
      \1  - name: GNB_IP
      \1    value: "{{ srsran_network.n3.gnb_ip }}"
      \1  - name: UE_IPS
      \1    value: "{{ srsran_network.n3.ue_ips | join(',') }}"
      \1  - name: UE_COUNT
      \1    value: "{{ ue_count }}"
      \2  - name: PATH\3

- name: Patch srsUE deployment - sleep infinity instead of start_ue.sh 1
  ansible.builtin.replace:
    path: "{{ repo_dest_abs }}/charts/srsue/templates/deployment.yaml"
    regexp: '/bin/bash /srsran/config/start_ue\.sh 1'
    replace: 'sleep infinity'

- name: Patch gNB n3network name in deployment template
  ansible.builtin.replace:
    path: "{{ repo_dest_abs }}/charts/srsran-gnb/templates/deployment.yaml"
    regexp: '"name":\s*"n3network"'
    replace: '"name": "{{ ''{{'' }} .Values.n3networkName {{ ''}}'' }}"'

- name: Patch srsUE n3network name in deployment template
  ansible.builtin.replace:
    path: "{{ repo_dest_abs }}/charts/srsue/templates/deployment.yaml"
    regexp: '"name":\s*"n3network"'
    replace: '"name": "{{ ''{{'' }} .Values.n3networkName {{ ''}}'' }}"'
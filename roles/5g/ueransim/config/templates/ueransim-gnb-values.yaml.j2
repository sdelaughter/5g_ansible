{#
  ueransim-gnb-values.yaml.j2
  Generates Helm values override for ueransim gNB chart (free5gc)
#}
{%- macro resolve_sd(sd) -%}
  {%- if sd == 'EMPTY' -%}0xFFFFFF
  {%- else -%}0x{{ '%06x' | format(sd | int(base=16)) }}
  {%- endif -%}
{%- endmacro -%}

global:
  n2network:
    enabled: true
    name: n2network
    type: ipvlan
    masterIf: eth0
    subnetIP: {{ net.n2.subnet_ip }}
    cidr: {{ net.n2.cidr }}
    gatewayIP: {{ net.n2.gateway }}
    excludeIP: {{ net.n2.gateway }}
  n3network:
    enabled: true
    name: n3network
    type: ipvlan
    masterIf: eth0
    subnetIP: {{ net.n3.subnet_ip }}
    cidr: {{ net.n3.cidr }}
    gatewayIP: {{ net.n3.gateway }}
    excludeIP: {{ net.n3.gateway }}

gnb:
  enabled: true

  n2if:
    ipAddress: {{ net.n2.gnb_ip }}
  n3if:
    ipAddress: {{ net.n3.gnb_ip }}

  amf:
    n2if:
      ipAddress: {{ net.n2.amf_ip }}
      port: 38412
    service:
      ngap:
        enabled: false

  nodeSelector:
    kubernetes.io/hostname: "{{ ran_node_name }}"

  configuration: |-
    mcc: '{{ profile.plmn.mcc }}'
    mnc: '{{ profile.plmn.mnc }}'
    nci: '0x000000010'
    idLength: 32
    tac: {{ profile.plmn.tac | int }}
    slices:
{% for slice in profile.slices %}
      - sst: {{ slice.sst | int }}
        sd: {{ resolve_sd(slice.sd) }}
{% endfor %}
    ignoreStreamIds: true

ue:
  enabled: false  # UEs deployed separately, one release per UE
